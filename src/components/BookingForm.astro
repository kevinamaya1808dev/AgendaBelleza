---
import { salonInfo, servicios } from '../data/salon.js';
---

<section id="agendar" class="max-w-3xl mx-auto px-5 py-24">
  <div class="bg-white [background-size:20px_20px] p-10 md:p-14 rounded-3xl shadow-2xl border border-pink-100 relative overflow-hidden">
    
    <div class="absolute top-0 right-0 -mt-10 -mr-10 w-40 h-40 bg-pink-100 rounded-full blur-3xl opacity-50 z-0"></div>

    <div class="text-center mb-10 relative z-10">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">Agendar Cita</h2>
      <p class="text-gray-500">Completa tus datos y confirmaremos tu espacio por WhatsApp.</p>
    </div>

    <form id="form-cita" data-telefono={salonInfo.whatsapp} class="space-y-6 relative z-10">
      
      <div>
        <label for="servicio" class="block text-sm font-bold text-gray-700 mb-2">Servicio de interés</label>
        <select id="servicio" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition-all cursor-pointer bg-white">
          <option value="" disabled selected>Selecciona un servicio...</option>
          {servicios.map((s) => (
            <option value={s.nombre}>{s.nombre} - {s.precio}</option>
          ))}
        </select>
      </div>

      <div>
        <label for="nombre" class="block text-sm font-bold text-gray-700 mb-2">Tu Nombre</label>
        <input type="text" id="nombre" placeholder="Ej. María Pérez" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition-all" />
      </div>

      <div>
        <label for="fecha" class="block text-sm font-bold text-gray-700 mb-2">Fecha y Hora deseada</label>
        <input type="datetime-local" id="fecha" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition-all" />
      </div>

      <button type="submit" class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-4 rounded-xl shadow-lg shadow-green-500/30 transition-all flex justify-center items-center gap-3 text-lg mt-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.876 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
        Confirmar por WhatsApp
      </button>
    </form>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    
    // 1. Escuchar los clics de las tarjetas para autoseleccionar el servicio
    const botonesAgendar = document.querySelectorAll('.btn-agendar');
    // Le decimos a TypeScript que esto es específicamente un elemento HTMLSelectElement
    const selectServicio = document.getElementById('servicio') as HTMLSelectElement;

    botonesAgendar.forEach(boton => {
      boton.addEventListener('click', () => {
        const nombreServicio = boton.getAttribute('data-servicio');
        // Solo intentamos asignar el valor si el select y el nombre del servicio existen
        if (selectServicio && nombreServicio) {
          selectServicio.value = nombreServicio;
        }
      });
    });

    // 2. Lógica para abrir WhatsApp al enviar el formulario
    // Le decimos a TypeScript que esto es un HTMLFormElement
    const form = document.getElementById('form-cita') as HTMLFormElement;
    
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();

        const telefono = form.getAttribute('data-telefono') || '';
        // Le decimos a TypeScript que estos son Input elements para poder leer su .value
        const servicioInput = document.getElementById('servicio') as HTMLSelectElement;
        const nombreInput = document.getElementById('nombre') as HTMLInputElement;
        const fechaInput = document.getElementById('fecha') as HTMLInputElement;
        
        // Verificamos que los inputs existan antes de sacarles el valor para evitar errores en rojo
        const servicio = servicioInput ? servicioInput.value : '';
        const nombre = nombreInput ? nombreInput.value : '';
        const fechaBruta = fechaInput ? fechaInput.value : '';
        
        const fechaObj = new Date(fechaBruta);
        // Usamos Intl.DateTimeFormat que es más estándar y menos propenso a quejarse
        const opciones: Intl.DateTimeFormatOptions = { weekday: 'long', month: 'long', day: 'numeric', hour: '2-digit', minute:'2-digit' };
        const fechaFormateada = fechaObj.toLocaleDateString('es-MX', opciones);
        
        const mensaje = `¡Hola! Me gustaría agendar una cita.%0A%0A💅 *Servicio:* ${servicio}%0A👤 *Nombre:* ${nombre}%0A📅 *Fecha:* ${fechaFormateada}%0A%0A¿Tienen disponibilidad?`;
        
        window.open(`https://wa.me/${telefono}?text=${mensaje}`, '_blank');
      });
    }
  });
</script>