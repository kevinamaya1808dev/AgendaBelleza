---
import { testimonios } from '../data/salon.js';
---

<section class="bg-gray-50 py-24">
  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Lo que dicen nuestras clientas</h2>
      <p class="text-gray-500">Tu satisfacción es nuestra prioridad</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonios.map((testimonio) => (
        <div class="bg-white [background-image:radial-gradient(#fbcfe8_1px,transparent_1px)] [background-size:20px_20px] p-8 rounded-3xl shadow-sm border border-gray-100 relative overflow-hidden transition-all duration-300 hover:shadow-lg">
          
          <div class="flex text-pink-400 mb-4 text-xl relative z-10">
            {"★".repeat(testimonio.estrellas)}
          </div>
          <p class="text-gray-600 italic mb-6 relative z-10">"{testimonio.comentario}"</p>
          <div class="flex items-center gap-3 relative z-10">
            <div class="w-10 h-10 bg-pink-100 rounded-full flex items-center justify-center text-pink-600 font-bold">
              {testimonio.nombre.charAt(0)}
            </div>
            <div>
              <h4 class="font-bold text-gray-900">{testimonio.nombre}</h4>
              <p class="text-xs text-gray-400 uppercase tracking-wide">{testimonio.servicio}</p>
            </div>
          </div>
          
        </div>
      ))}
    </div>
  </div>
</section>