---
const { salonName } = Astro.props;
---
<footer class="bg-gray-900 text-white py-12 mt-12">
  <div class="max-w-6xl mx-auto px-5 text-center">
    <h2 class="text-2xl font-bold mb-4">{salonName}</h2>
    <p class="text-gray-400 mb-8">Haciendo resaltar tu belleza todos los días.</p>
    <div class="border-t border-gray-800 pt-8 text-sm text-gray-500">
      &copy; 2026 {salonName}. Todos los derechos reservados.
    </div>
  </div>
</footer>