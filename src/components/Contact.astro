---
import { salonInfo } from '../data/salon.js';
---

<section id="contacto" class="bg-white py-24 border-y border-pink-50">
  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Contáctanos</h2>
      <p class="text-gray-500">Estamos listas para resolver tus dudas y agendar tu cita.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <div class="bg-white [background-image:radial-gradient(#fbcfe8_1px,transparent_1px)] [background-size:20px_20px] p-8 rounded-3xl text-center border border-pink-100 shadow-sm hover:shadow-md transition-all">
        <div class="bg-pink-100 w-14 h-14 mx-auto rounded-full flex items-center justify-center text-pink-600 mb-4 relative z-10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 relative z-10">Teléfono</h3>
        <p class="text-gray-600 font-medium relative z-10">{salonInfo.telefono}</p>
      </div>

      <div class="bg-white [background-image:radial-gradient(#fbcfe8_1px,transparent_1px)] [background-size:20px_20px] p-8 rounded-3xl text-center border border-pink-100 shadow-sm hover:shadow-md transition-all">
        <div class="bg-pink-100 w-14 h-14 mx-auto rounded-full flex items-center justify-center text-pink-600 mb-4 relative z-10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 relative z-10">Correo Electrónico</h3>
        <p class="text-gray-600 font-medium relative z-10">{salonInfo.email}</p>
      </div>

      <div class="bg-white [background-image:radial-gradient(#fbcfe8_1px,transparent_1px)] [background-size:20px_20px] p-8 rounded-3xl text-center border border-pink-100 shadow-sm hover:shadow-md transition-all">
        <div class="bg-pink-100 w-14 h-14 mx-auto rounded-full flex items-center justify-center text-pink-600 mb-4 relative z-10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 relative z-10">Horario de Atención</h3>
        <p class="text-gray-600 font-medium relative z-10">{salonInfo.horarios}</p>
      </div>

    </div>
  </div>
</section>

<section id="ubicacion" class="max-w-6xl mx-auto px-5 py-24">
  <div class="bg-white rounded-3xl shadow-xl overflow-hidden flex flex-col md:flex-row border border-gray-100">
    
    <div class="w-full md:w-1/3 p-10 bg-gray-900 text-white flex flex-col justify-center">
      <h3 class="text-3xl font-bold mb-6">Nuestra Ubicación</h3>
      <p class="text-gray-400 mb-8">Ven a visitarnos. Tenemos instalaciones cómodas y seguras listas para consentirte.</p>
      
      <div class="flex items-start gap-4">
        <div class="bg-pink-500 p-3 rounded-full text-white">
           <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        </div>
        <div>
          <h4 class="font-bold text-xl mb-2">Dirección</h4>
          <p class="text-gray-300 leading-relaxed">{salonInfo.direccion}</p>
        </div>
      </div>
    </div>

    <div class="w-full md:w-2/3 h-80 md:h-[400px]">
      <iframe 
        src={salonInfo.mapaEmbed} 
        width="100%" 
        height="100%" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade"
        class="w-full h-full object-cover">
      </iframe>
    </div>

  </div>
</section>